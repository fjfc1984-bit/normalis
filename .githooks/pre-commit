#!/bin/sh
# .githooks/pre-commit
# Compatible con Linux/Mac (bash) y Windows (Git for Windows sh)
# Instalacion: git config core.hooksPath .githooks
# Corre automaticamente en cada git commit.

if ! command -v bash >/dev/null 2>&1; then
  echo "  [INFO] bash no disponible — saltando validacion NormaLis"
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo ""
echo "============================================================"
echo "  NormaLis — Validacion pre-commit (validador maestro)"
echo "============================================================"

# Determinar si algun archivo JS/HTML/CSS fue modificado
MODIFIED=$(git diff --cached --name-only)
JS_HTML_CHANGED=$(echo "$MODIFIED" | grep -qE '\.(html|js|css)$' && echo "1" || echo "0")

# Si no se modifico nada relevante y no es full check, pasar
if [ "$JS_HTML_CHANGED" = "0" ] && [ "${NORMALIS_FULL_CHECK:-0}" != "1" ]; then
  echo "  Sin cambios en HTML/JS/CSS — saltando validacion"
  echo "  COMMIT AUTORIZADO"
  echo "============================================================"
  exit 0
fi

# Correr el validador maestro
if [ -f "$REPO_ROOT/normalis-validate.sh" ]; then
  if bash "$REPO_ROOT/normalis-validate.sh" 2>&1; then
    echo ""
    echo "============================================================"
    echo "  COMMIT AUTORIZADO"
    echo "============================================================"
    echo ""
    exit 0
  else
    echo ""
    echo "============================================================"
    echo "  COMMIT BLOQUEADO — corrige los errores criticos primero"
    echo "  Ejecuta: bash normalis-validate.sh --verbose"
    echo "============================================================"
    echo ""
    exit 1
  fi
else
  # Fallback: validadores individuales si no existe el maestro
  echo "  [WARN] normalis-validate.sh no encontrado, usando validadores individuales"
  ERRORS=0

  if echo "$MODIFIED" | grep -q 'admin.html' || [ "${NORMALIS_FULL_CHECK:-0}" = "1" ]; then
    if [ -f "$REPO_ROOT/validate-admin.sh" ]; then
      bash "$REPO_ROOT/validate-admin.sh" "$REPO_ROOT/admin.html" || ERRORS=$((ERRORS+1))
    fi
  fi

  if echo "$MODIFIED" | grep -q 'login.html' || [ "${NORMALIS_FULL_CHECK:-0}" = "1" ]; then
    if [ -f "$REPO_ROOT/validate-login.sh" ]; then
      bash "$REPO_ROOT/validate-login.sh" "$REPO_ROOT/login.html" || ERRORS=$((ERRORS+1))
    fi
  fi

  if [ "$ERRORS" -eq 0 ]; then
    echo "  COMMIT AUTORIZADO"; exit 0
  else
    echo "  COMMIT BLOQUEADO — $ERRORS errores criticos"; exit 1
  fi
fi
